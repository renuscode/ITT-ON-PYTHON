class Solution:
    def generateParenthesis(self, n: int) -> List[str]:
        result = []

        def backtrack(s="", open_count=0, close_count=0):
            # If the current string s is complete
            if len(s) == 2 * n:
                result.append(s)
                return
            
            # Add an open parenthesis if possible
            if open_count < n:
                backtrack(s + "(", open_count + 1, close_count)
            
            # Add a close parenthesis if it won't exceed open ones
            if close_count < open_count:
                backtrack(s + ")", open_count, close_count + 1)
        
        backtrack()
        return result
